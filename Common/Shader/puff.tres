code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D tex_vtx_8;
uniform float FloatParameter = 0.30000001192093;
uniform sampler2D depth_tex_frg_4 : hint_depth_texture;



void vertex() {
// Input:4
	vec3 n_out4p0 = VERTEX;


// Input:11
	float n_out11p0 = TIME;


// Vector2Constant:14
	vec2 n_out14p0 = vec2(0.100000, 1.000000);


// VectorOp:12
	vec3 n_out12p0 = vec3(n_out11p0) * vec3(n_out14p0, 0.0);


// UVFunc:10
	vec2 n_in10p1 = vec2(1.00000, 1.00000);
	vec2 n_out10p0 = vec2(n_out12p0.xy) * n_in10p1 + UV;


// Texture2D:8
	vec4 n_out8p0 = texture(tex_vtx_8, n_out10p0);
	float n_out8p1 = n_out8p0.r;


// Input:5
	vec3 n_out5p0 = NORMAL;


// VectorOp:9
	vec3 n_out9p0 = vec3(n_out8p1) * n_out5p0;


// FloatConstant:7
	float n_out7p0 = 0.300000;


// VectorOp:6
	vec3 n_out6p0 = n_out9p0 * vec3(n_out7p0);


// VectorOp:3
	vec3 n_out3p0 = n_out4p0 + n_out6p0;


// Output:0
	VERTEX = n_out3p0;


}

void fragment() {
// Input:2
	vec4 n_out2p0 = COLOR;
	float n_out2p4 = n_out2p0.a;


// FloatParameter:5
	float n_out5p0 = FloatParameter;


	float n_out4p0;
// ProximityFade:4
	{
		float __depth_tex = texture(depth_tex_frg_4, SCREEN_UV).r;
		vec4 __depth_world_pos = INV_PROJECTION_MATRIX * vec4(SCREEN_UV * 2.0 - 1.0, __depth_tex, 1.0);
		__depth_world_pos.xyz /= __depth_world_pos.w;
		n_out4p0 = clamp(1.0 - smoothstep(__depth_world_pos.z + n_out5p0, __depth_world_pos.z, VERTEX.z), 0.0, 1.0);
	}


// FloatOp:3
	float n_out3p0 = n_out4p0 * n_out2p4;


// Output:0
	ALBEDO = vec3(n_out2p0.xyz);
	ALPHA = n_out3p0;


}

void light() {
// FloatConstant:6
	float n_out6p0 = 0.000000;


// FloatConstant:7
	float n_out7p0 = 0.100000;


// Input:2
	vec3 n_out2p0 = NORMAL;


// Fresnel:4
	float n_in4p3 = 1.00000;
	float n_out4p0 = pow(clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_in4p3);


// DotProduct:3
	float n_out3p0 = dot(n_out2p0, vec3(n_out4p0));


// SmoothStep:5
	vec3 n_out5p0 = smoothstep(vec3(n_out6p0), vec3(n_out7p0), vec3(n_out3p0));


// FloatConstant:9
	float n_out9p0 = 0.100000;


// FloatConstant:10
	float n_out10p0 = 1.000000;


// Clamp:8
	vec3 n_out8p0 = clamp(n_out5p0, vec3(n_out9p0), vec3(n_out10p0));


// Output:0
	DIFFUSE_LIGHT = n_out8p0;


}
